{
  "name": "ai-service-desk",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered service desk automation platform microservices monorepo.",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel -r dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r --sort build && pnpm -r typecheck",
    "dev:frontend": "pnpm --filter @ai-service-desk/frontend dev",
    "dev:gateway": "pnpm --filter @ai-service-desk/api-gateway dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
