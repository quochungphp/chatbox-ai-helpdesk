{
  "name": "ai-service-desk",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered service desk automation platform microservices monorepo.",
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev": "corepack pnpm --parallel -r dev",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r --sort build && corepack pnpm -r typecheck",
    "dev:services": "corepack pnpm --parallel --filter @ai-service-desk/api-gateway --filter @ai-service-desk/audit-service --filter @ai-service-desk/auth-service --filter @ai-service-desk/ai-service --filter @ai-service-desk/banking-service --filter @ai-service-desk/rag-service --filter @ai-service-desk/chatbot-service --filter @ai-service-desk/notification-service --filter @ai-service-desk/ticket-service dev",
    "dev:frontend": "corepack pnpm --filter @ai-service-desk/frontend dev",
    "dev:gateway": "corepack pnpm --filter @ai-service-desk/api-gateway dev",
    "simulator:migrate": "corepack pnpm --filter @ai-service-desk/simulator migrate",
    "simulator:seed": "corepack pnpm --filter @ai-service-desk/simulator seed",
    "simulator:reset": "corepack pnpm --filter @ai-service-desk/simulator reset",
    "simulator:health": "corepack pnpm --filter @ai-service-desk/simulator health",
    "simulator:e2e": "corepack pnpm --filter @ai-service-desk/simulator e2e",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
